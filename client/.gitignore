node_modules/
.pnp
.pnp.js

# --- Build Outputs ---
# For Vite, React (CRA), or Next.js
dist/
dist-ssr/
build/
out/
.next/
bin/
obj/

# --- Environment Variables (CRITICAL) ---
# Never push your actual API keys or DB URLs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sln
*.swp
*.suo

# --- Testing ---
coverage/
.nyc_output

