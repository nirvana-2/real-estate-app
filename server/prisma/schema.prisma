generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  password      String
  role          Role

  isAgent       Boolean       @default(false)
  agentBio      String?
  agentPhone    String?
  agentPhoto    String?
  specialty     AgentSpecialty?

  properties    Property[]
  applications  Application[]
  payments      Payment[]

  // Back-relations
  bookings      Booking[] @relation("TenantBookings")
  favorites     Favorite[]
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Property {
  id            Int           @id @default(autoincrement())
  title         String
  description   String
  price         Float
  location      String
  landlordId    Int
  landlord      User          @relation(fields: [landlordId], references: [id])

  listingType   ListingType   @default(RENT)
  propertyType  PropertyType
  bedrooms      Int
  bathrooms     Int
  areaSqFt      Float
  amenities     Json?
  images        String[]      @default([])
  available     Boolean       @default(true)
  latitude      Float?
  longitude     Float?

  applications  Application[]
  payments      Payment[]

  // Back-relations
  bookings      Booking[]
  favorites     Favorite[]
   messages      Message[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ListingType {
  RENT
  SALE
}


model Application {
  id          Int              @id @default(autoincrement())
  tenantId    Int
  tenant      User             @relation(fields: [tenantId], references: [id])
  propertyId  Int
  property    Property         @relation(fields: [propertyId], references: [id])

  message     String?
  incomeProof String?
  moveInDate  DateTime?
  status      ApplicationStatus @default(PENDING)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Payment {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  tenant      User         @relation(fields: [tenantId], references: [id])
  propertyId  Int
  property    Property     @relation(fields: [propertyId], references: [id])

  amount      Float
  currency    String
  paymentDate DateTime     @default(now())
  paymentType PaymentType
  status      PaymentStatus @default(PENDING)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Booking {
  id         Int      @id @default(autoincrement())
  date       DateTime
  status     BookingStatus @default(PENDING)

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId Int
  tenant     User     @relation("TenantBookings", fields: [tenantId], references: [id])
  tenantId   Int

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Favorite {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
}
model Message {
  id         Int      @id @default(autoincrement())
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  senderId   Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
}

enum Role {
  ADMIN
  LANDLORD
  TENANT
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentType {
  RENT
  DEPOSIT
  APPLICATION_FEE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
 
enum AgentSpecialty {
  LUXURY
  RESIDENTIAL
  COMMERCIAL
  NEW_CONSTRUCTION
}